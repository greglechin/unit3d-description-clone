{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "dotnet: build",
            "program": "${workspaceFolder}/src/bin/Debug/net10.0/unit3d-description-clone.dll",
            "args": [
                "602723"
            ],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            // Enable launching the same program multiple times with different arguments.
            // See https://aka.ms/vscode-remote/launch-multiple for details.
            "internalConsoleOptions": "openOnSessionStart"
        }
    ]
}